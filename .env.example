# AIGF 模型 API 配置（复制为 .env 后填入）

# 编排 / 编程 / 智能规划（OpenAI 兼容 API）
AIGF_LLM_API_KEY=
AIGF_LLM_BASE_URL=https://api.openai.com/v1
AIGF_LLM_MODEL=gpt-4o

# 生图 Agent（OpenAI DALL·E 3）
AIGF_IMAGE_API_KEY=
AIGF_IMAGE_MODEL=dall-e-3

# 音频 Agent（OpenAI TTS）
AIGF_AUDIO_API_KEY=
AIGF_AUDIO_MODEL=tts-1
AIGF_AUDIO_VOICE=alloy

# 视频 Agent — local（ffmpeg 降级）| replicate | runway | kling
AIGF_VIDEO_API_KEY=
AIGF_VIDEO_PROVIDER=local

# Replicate（开源友好）https://replicate.com/account/api-tokens
# AIGF_VIDEO_PROVIDER=replicate
# AIGF_VIDEO_MODEL=stability-ai/stable-video-diffusion-img2vid-xt

# Runway 直连 https://dev.runwayml.com
# AIGF_VIDEO_PROVIDER=runway
# AIGF_VIDEO_API_KEY=
# AIGF_VIDEO_MODEL=gen3a_turbo
# AIGF_VIDEO_BASE_URL=https://api.dev.runwayml.com/v1
# AIGF_RUNWAY_VERSION=2024-11-06

# Kling 可灵 — Bearer 代理（如 klingapi.com）
# AIGF_VIDEO_PROVIDER=kling
# AIGF_VIDEO_API_KEY=
# AIGF_VIDEO_MODEL=kling-v2.5-turbo
# AIGF_VIDEO_BASE_URL=https://api.klingapi.com

# Kling 官方直连（JWT，无需 AIGF_VIDEO_API_KEY）
# AIGF_VIDEO_PROVIDER=kling
# AIGF_KLING_ACCESS_KEY=
# AIGF_KLING_SECRET_KEY=
# AIGF_VIDEO_MODEL=kling-v1-6
# AIGF_VIDEO_BASE_URL=https://api.klingai.com
